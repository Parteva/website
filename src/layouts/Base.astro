---
import '../styles/global.css';
import { copy } from '../content/copy';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${copy.brand} · ${copy.brandTagline}`,
  description = 'Veri odaklı pazarlama, kusursuz operasyon ve yapay zeka destekli araçlarla e-ticaret markanızı büyütürken kârlılığınızı artırıyoruz.',
} = Astro.props;

const ogImage = '/og.jpg';
const siteUrl = 'https://parteva.com';
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c0a09" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="tr_TR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: copy.brand,
      url: siteUrl,
      description,
      sameAs: [copy.contact.instagram, copy.contact.linkedin],
    })} />

    <title>{title}</title>
  </head>
  <body>
    <!-- Custom cursor -->
    <div id="cursor-dot" aria-hidden="true"></div>
    <div id="cursor-ring" aria-hidden="true"></div>

    <slot />

    <!-- WhatsApp floating button -->
    <div style="position: fixed; bottom: 1.75rem; right: 1.75rem; z-index: 50; display: flex; flex-direction: column; align-items: flex-end; gap: 0.75rem;">

      <!-- Bubble -->
      <div
        id="wa-bubble"
        style="
          background: var(--bg-elev);
          border: 1px solid color-mix(in srgb, var(--text-faint) 60%, transparent);
          padding: 0.65rem 1rem;
          max-width: 200px;
          box-shadow: 0 8px 32px rgba(0,0,0,0.14);
          opacity: 0;
          transform: translateY(6px);
          transition: opacity 0.4s ease, transform 0.4s ease;
          pointer-events: none;
          position: relative;
        "
      >
        <div style="display: flex; align-items: center; gap: 0.6rem;">
          <p style="font-family: 'DM Sans', sans-serif; font-size: 0.72rem; font-weight: 300; color: var(--text-dim); line-height: 1.5; white-space: nowrap;">
            İşinizi beraber zirveye taşıyalım
          </p>
          <button
            id="wa-bubble-close"
            aria-label="Kapat"
            style="
              flex-shrink: 0;
              background: none;
              border: none;
              cursor: pointer;
              color: var(--text-faint);
              font-size: 0.75rem;
              line-height: 1;
              padding: 0;
              transition: color 0.2s;
            "
            onmouseover="this.style.color='var(--text)'"
            onmouseout="this.style.color='var(--text-faint)'"
          >✕</button>
        </div>
        <!-- Arrow -->
        <span style="
          position: absolute;
          bottom: -5px;
          right: 18px;
          width: 9px;
          height: 9px;
          background: var(--bg-elev);
          border-right: 1px solid color-mix(in srgb, var(--text-faint) 60%, transparent);
          border-bottom: 1px solid color-mix(in srgb, var(--text-faint) 60%, transparent);
          transform: rotate(45deg);
        "></span>
      </div>

      <!-- Button -->
      <a
        href="https://wa.me/905379397212"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp ile iletişime geç"
        id="wa-btn"
        style="
          width: 48px;
          height: 48px;
          border-radius: 50%;
          background: var(--text);
          color: var(--bg);
          display: flex;
          align-items: center;
          justify-content: center;
          box-shadow: 0 4px 24px rgba(0,0,0,0.18);
          transition: background 0.3s, transform 0.3s;
        "
        onmouseover="this.style.background='var(--accent)';this.style.transform='scale(1.08)'"
        onmouseout="this.style.background='var(--text)';this.style.transform='scale(1)'"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </a>
    </div>

    <script>
      const bubble = document.getElementById('wa-bubble');
      const closeBtn = document.getElementById('wa-bubble-close');

      if (bubble) {
        setTimeout(() => {
          bubble.style.opacity = '1';
          bubble.style.transform = 'translateY(0)';
          bubble.style.pointerEvents = 'auto';
        }, 2500);
      }

      closeBtn?.addEventListener('click', () => {
        if (bubble) {
          bubble.style.opacity = '0';
          bubble.style.transform = 'translateY(6px)';
          bubble.style.pointerEvents = 'none';
        }
      });
    </script>

    <script>
      import { initScroll } from '../lib/scroll';
      import { initRevealAll, pageEntrance, initSectionBeams } from '../lib/motion';

      document.addEventListener('DOMContentLoaded', () => {
        initScroll();
        pageEntrance();
        setTimeout(() => { initRevealAll(); initSectionBeams(); }, 100);
      });

      // Custom cursor
      const dot = document.getElementById('cursor-dot');
      const ring = document.getElementById('cursor-ring');

      if (dot && ring && window.matchMedia('(pointer: fine)').matches) {
        let aimX = 0, aimY = 0;
        let currentX = 0, currentY = 0;

        document.addEventListener('mousemove', (e) => {
          aimX = e.clientX;
          aimY = e.clientY;
          dot.style.left = `${aimX}px`;
          dot.style.top = `${aimY}px`;
        });

        function animateRing() {
          currentX += (aimX - currentX) * 0.12;
          currentY += (aimY - currentY) * 0.12;
          ring.style.left = `${currentX}px`;
          ring.style.top = `${currentY}px`;
          requestAnimationFrame(animateRing);
        }
        animateRing();

        document.querySelectorAll('a, button, [role="button"]').forEach((el) => {
          el.addEventListener('mouseenter', () => ring.classList.add('hovered'));
          el.addEventListener('mouseleave', () => ring.classList.remove('hovered'));
        });
      }
    </script>
  </body>
</html>
