---
import { copy } from '../content/copy';

const screenshotFiles: Record<string, string> = {
  'Letafia':           '/clients/screenshots/letafia.jpg',
  'Lesshome':          '/clients/screenshots/lesshome.jpg',
  'Peters Lojistik':   '/clients/screenshots/peters-lojistik.jpg',
  'EnDeneyim Merkezi': '/clients/screenshots/endeneyim-merkezi.jpg',
  'Simetri Eğitim':    '/clients/screenshots/simetri-egitim.jpg',
};
---

<section
  id="islerimiz"
  data-reveal
  class="py-20 md:py-28"
>
  <div class="max-w-[1280px] mx-auto px-8 md:px-16">

    <!-- Section header -->
    <div class="mb-16 md:mb-24 text-center">
      <p class="eyebrow reveal-item mb-6">Referanslar</p>
      <h2 class="display-heading reveal-item mx-auto" style="max-width: 20ch;">
        Bize güvenen<br />
        <em>markalar</em>
      </h2>
      <p class="text-[--text-dim] reveal-item text-sm leading-relaxed mx-auto mt-6" style="max-width: 44ch;">
        Moda'dan lojistiğe, ev yaşamından eğitime; sektörden bağımsız, sonuç odaklı büyüme ortaklıkları.
      </p>
    </div>

    <!-- Client cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {copy.work.map((client) => (
        <a
          href={client.url}
          target="_blank"
          rel="noopener noreferrer"
          class="work-card group relative bg-[--bg-elev] overflow-hidden reveal-item block"
          style="border: 1px solid color-mix(in srgb, var(--text-faint) 40%, transparent);"
          aria-label={`${client.brand} — ${client.sector}`}
        >
          <!-- Website screenshot — grayscale by default, full color on hover -->
          <div
            class="relative w-full overflow-hidden client-visual bg-[--bg]"
            style="aspect-ratio: 16/10; filter: grayscale(0) opacity(1); transition: filter 0.5s ease;"
          >
            <img
              src={screenshotFiles[client.brand]}
              alt={`${client.brand} web sitesi`}
              class="absolute inset-0 w-full h-full object-contain transition-transform duration-700 group-hover:scale-105"
              draggable="false"
              loading="lazy"
            />

            <!-- Hover tint -->
            <div
              class="absolute inset-0 bg-[--accent] opacity-0 group-hover:opacity-5 transition-opacity duration-300"
              aria-hidden="true"
            ></div>
          </div>

          <!-- Info -->
          <div class="p-6 md:p-8 flex flex-col gap-2">
            <div class="flex items-center justify-between">
              <h3
                class="font-display text-[--text] group-hover:text-[--accent] transition-colors duration-300"
                style="font-size: clamp(1.2rem, 1.8vw, 1.5rem); font-weight: 300;"
              >
                {client.brand}
              </h3>
              <!-- External link indicator -->
              <span
                class="text-[--text-faint] group-hover:text-[--accent] transition-colors duration-300 opacity-0 group-hover:opacity-100"
                style="font-size: 0.75rem;"
                aria-hidden="true"
              >
                ↗
              </span>
            </div>

            <div class="flex items-center gap-3 flex-wrap">
              <span
                class="text-[--text-faint] uppercase"
                style="font-size: 0.62rem; letter-spacing: 0.25em;"
              >
                {client.sector}
              </span>
              <span class="text-[--text-faint]" aria-hidden="true">·</span>
              <span
                class="text-[--accent] uppercase"
                style="font-size: 0.62rem; letter-spacing: 0.18em;"
              >
                {client.metric}
              </span>
            </div>

            <!-- Services list -->
            <p
              class="text-[--text-faint] leading-relaxed"
              style="font-size: 0.62rem; letter-spacing: 0.08em; margin-top: 4px;"
            >
              {client.services}
            </p>
          </div>
        </a>
      ))}
    </div>

    <!-- Portfolio note -->
    <p class="reveal-item mt-12 text-center text-[--text-faint]" style="font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;">
      Farklı sektörler · Ölçülebilir sonuçlar
    </p>

  </div>
</section>

<script>
  import { gsap } from 'gsap';

  // Grayscale → color on hover
  document.querySelectorAll('.work-card').forEach((card) => {
    const visual = card.querySelector('.client-visual') as HTMLElement;

    card.addEventListener('mouseenter', () => {
      if (visual) visual.style.filter = 'grayscale(0) opacity(1)';
      gsap.to(card, { scale: 1.01, duration: 0.3, ease: 'power2.out' });
    });
    card.addEventListener('mouseleave', () => {
      if (visual) visual.style.filter = 'grayscale(0) opacity(1)';
      gsap.to(card, { scale: 1, duration: 0.3, ease: 'power2.out' });
    });
  });
</script>
