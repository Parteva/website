---
import { copy } from '../content/copy';
---

<section
  id="iletisim"
  data-reveal
  class="py-20 md:py-28"
>
  <div class="max-w-[1280px] mx-auto px-8 md:px-16">
    <div class="mb-16 md:mb-20 text-center">
      <p class="eyebrow reveal-item mb-6">İletişim</p>
      <h2 class="display-heading reveal-item mx-auto" style="max-width: 18ch;">
        Markanızı birlikte<br />
        <em>büyütelim</em>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 md:gap-24 items-start">
      <!-- Left: contact info -->
      <div class="flex flex-col gap-10">
        <!-- Email -->
        <div class="reveal-item">
          <p class="eyebrow mb-3" style="color: var(--text-faint);">E-posta</p>
          <a
            href={`mailto:${copy.contact.email}`}
            class="font-display text-[--text] hover:text-[--accent] transition-colors duration-300 block"
            style="font-size: clamp(1.4rem, 2.5vw, 2rem); font-weight: 300; text-decoration: underline; text-underline-offset: 6px; text-decoration-color: var(--text-faint);"
          >
            {copy.contact.email}
          </a>
        </div>

        <!-- Location -->
        <div class="reveal-item">
          <p class="eyebrow mb-3" style="color: var(--text-faint);">Konum</p>
          <p class="font-display text-[--text-dim]"
             style="font-size: 1.1rem; font-weight: 300;">
            {copy.contact.location}
          </p>
        </div>

        <!-- Social -->
        <div class="reveal-item">
          <p class="eyebrow mb-4" style="color: var(--text-faint);">Sosyal</p>
          <div class="flex gap-6">
            <a
              href={copy.contact.instagram}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
              class="text-[--text-dim] hover:text-[--accent] transition-colors duration-300 flex items-center gap-2"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
              </svg>
              <span style="font-size: 0.75rem; letter-spacing: 0.12em;">Instagram</span>
            </a>
            <a
              href={copy.contact.twitter}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="X (Twitter)"
              class="text-[--text-dim] hover:text-[--accent] transition-colors duration-300 flex items-center gap-2"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              <span style="font-size: 0.75rem; letter-spacing: 0.12em;">X</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div id="form-success" class="hidden flex flex-col gap-4 reveal-item py-12">
        <p class="font-display text-[--text]" style="font-size: clamp(1.4rem, 2.5vw, 2rem); font-weight: 300;">
          Mesajınız alındı.
        </p>
        <p class="text-[--text-dim] text-sm leading-relaxed">
          En kısa sürede sizinle iletişime geçeceğiz.
        </p>
      </div>

      <form
        id="contact-form"
        class="flex flex-col gap-6 reveal-item"
        novalidate
      >
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="name" class="eyebrow" style="color: var(--text-faint);">Ad Soyad</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Parteva"
              class="form-input"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="email" class="eyebrow" style="color: var(--text-faint);">E-posta</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="hello@parteva.com"
              class="form-input"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="company" class="eyebrow" style="color: var(--text-faint);">Şirket / Marka</label>
            <input
              type="text"
              id="company"
              name="company"
              placeholder="Marka Adı"
              class="form-input"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label for="phone" class="eyebrow" style="color: var(--text-faint);">Telefon</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              placeholder="+90 5xx xxx xx xx"
              class="form-input"
            />
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label for="message" class="eyebrow" style="color: var(--text-faint);">Mesaj</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            placeholder="Markanızdan ve hedeflerinizden bahsedin…"
            class="form-input resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          id="form-submit-btn"
          class="self-start eyebrow transition-colors duration-300"
          style="
            background: var(--text);
            color: var(--bg);
            padding: 0.9rem 2.5rem;
            font-size: 0.68rem;
            letter-spacing: 0.25em;
          "
          onmouseover="this.style.background='var(--accent)'"
          onmouseout="this.style.background='var(--text)'"
        >
          Gönder
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxanERaVXc9DG3wlyz55VCIGvtHYB-R0w388LVDV36Ng5cacoFx-iQvAKXht-8P91M/exec';

  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success') as HTMLElement;
  const btn     = document.getElementById('form-submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Gönderiliyor…';

    const data = {
      name:    (form.elements.namedItem('name')    as HTMLInputElement).value,
      email:   (form.elements.namedItem('email')   as HTMLInputElement).value,
      company: (form.elements.namedItem('company') as HTMLInputElement).value,
      phone:   (form.elements.namedItem('phone')   as HTMLInputElement).value,
      message: (form.elements.namedItem('message') as HTMLTextAreaElement).value,
    };

    fetch(SCRIPT_URL, {
      method: 'POST',
      mode: 'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    }).catch(() => {});

    form.classList.add('hidden');
    success.classList.remove('hidden');
  });
</script>

<style>
  .form-input {
    background: var(--bg-elev);
    border: 1px solid var(--text-faint);
    color: var(--text);
    padding: 0.85rem 1rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 300;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }

  .form-input::placeholder {
    color: var(--text-faint);
  }

  .form-input:focus {
    border-color: var(--text-dim);
  }
</style>
