---
import { copy } from '../content/copy';
---

<footer class="border-t border-[--text-faint] py-12 md:py-16">
  <div class="max-w-[1280px] mx-auto px-8 md:px-16">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      <!-- Left: wordmark + motto -->
      <div class="flex flex-col gap-2">
        <a
          href="/"
          class="font-display text-xl text-[--text] hover:text-[--accent] transition-colors duration-300"
          style="font-weight: 300;"
        >
          {copy.brand}
        </a>
        <p class="text-[--text-faint] text-xs" style="letter-spacing: 0.05em;">
          {copy.footer.motto}
        </p>
      </div>

      <!-- Center: nav links -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Footer navigasyon">
        {copy.nav.links.map((link) => (
          <a
            href={link.href}
            class="text-[--text-faint] hover:text-[--text-dim] transition-colors duration-300"
            style="font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase;"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right: social + copyright -->
      <div class="flex flex-col gap-3 md:items-end">
        <div class="flex gap-5">
          <a
            href={copy.contact.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[--text-faint] hover:text-[--accent] transition-colors duration-300"
            aria-label="Instagram"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <a
            href={copy.contact.twitter}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[--text-faint] hover:text-[--accent] transition-colors duration-300"
            aria-label="X (Twitter)"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
        <p class="text-[--text-faint]" style="font-size: 0.65rem; letter-spacing: 0.05em;">
          {copy.footer.copyright}
        </p>
      </div>
    </div>
  </div>
</footer>
